<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>國小數學知識地圖</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: system-ui, sans-serif; background: #f1f5f9; display: flex; height: 100vh; overflow: hidden; font-size: 14px; }

/* ── 左側 vis 面板 ── */
#vis-panel { flex: 1; position: relative; overflow: hidden; }
#vis-container { width: 100%; height: 100%; }

/* ── 工具列覆蓋層 ── */
#toolbar {
  position: absolute; top: 10px; left: 10px; z-index: 10;
  background: rgba(255,255,255,0.93); border: 1px solid #e2e8f0;
  border-radius: 10px; padding: 8px 12px;
  display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
  box-shadow: 0 2px 8px rgba(0,0,0,.08);
}
.tb-sep { width: 1px; height: 20px; background: #e2e8f0; margin: 0 2px; }
.tb-label { font-size: 10px; font-weight: 700; color: #94a3b8; letter-spacing: .06em; cursor: pointer; user-select: none; }
.tb-label:hover { color: #64748b; }
.mode-btn { padding: 3px 10px; border-radius: 16px; border: 1.5px solid #cbd5e1; background: white; color: #64748b; font-size: 11px; cursor: pointer; transition: all .15s; }
.mode-btn.active { background: #1e293b; color: white; border-color: #1e293b; }
#search-box { padding: 3px 10px; border-radius: 16px; border: 1.5px solid #cbd5e1; font-size: 11px; outline: none; width: 120px; }
#search-box:focus { border-color: #94a3b8; }
.tb-select { padding: 3px 8px; border-radius: 16px; border: 1.5px solid #cbd5e1; font-size: 11px; color: #64748b; outline: none; cursor: pointer; background: white; }
.tb-select:focus { border-color: #94a3b8; }
.zoom-btn { min-width: 34px; padding: 3px 7px; border-radius: 16px; border: 1.5px solid #cbd5e1; background: white; color: #64748b; font-size: 11px; cursor: pointer; transition: all .15s; }
.zoom-btn:hover { border-color: #94a3b8; color: #334155; }
.zoom-btn.active { background: #1e293b; border-color: #1e293b; color: white; }
.zoom-fit-btn { min-width: 62px; }

/* ── 主線圖例（工具列下方展開） ── */
#strand-legend {
  display: none; position: absolute; top: 100%; left: 0; margin-top: 4px;
  background: rgba(255,255,255,0.97); border: 1px solid #e2e8f0;
  border-radius: 8px; padding: 8px 12px;
  flex-wrap: wrap; gap: 4px 10px; max-width: 420px;
  box-shadow: 0 2px 8px rgba(0,0,0,.08); z-index: 11;
}
#strand-legend.open { display: flex; }
.legend-item { display: flex; align-items: center; gap: 4px; font-size: 10px; color: #64748b; white-space: nowrap; }
.legend-item i { width: 8px; height: 8px; border-radius: 50%; display: inline-block; flex-shrink: 0; }

/* ── 右側卡片面板 ── */
#card-panel { width: 380px; min-width: 380px; background: white; border-left: 1px solid #e2e8f0; overflow-y: auto; }
#card-panel.hidden { display: none; }

.card-empty { display: flex; align-items: center; justify-content: center; height: 100%; color: #94a3b8; text-align: center; padding: 32px; font-size: 15px; line-height: 1.6; }
.card-content { padding: 20px 22px 24px; }
.card-badge { display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 11px; font-weight: 700; margin-bottom: 8px; }
.card-title { font-size: 22px; font-weight: 800; color: #1e293b; margin-bottom: 10px; line-height: 1.25; }
.card-summary { color: #64748b; font-size: 14px; line-height: 1.65; margin-bottom: 14px; }
.card-tabs { position: sticky; top: 0; z-index: 2; display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; background: white; padding: 8px 0 12px; border-bottom: 1px solid #f1f5f9; margin-bottom: 12px; }
.card-tab-btn { border: 1px solid #cbd5e1; background: #f8fafc; color: #475569; border-radius: 8px; padding: 8px 6px; font-size: 14px; font-weight: 700; cursor: pointer; }
.card-tab-btn.active { background: #1e293b; border-color: #1e293b; color: white; }
.card-tab-btn:hover { border-color: #94a3b8; }
.section-label { font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: .06em; color: #64748b; margin: 16px 0 8px; }
.traj-item { display: flex; align-items: center; gap: 8px; padding: 7px 10px; border-radius: 8px; font-size: 12px; margin-bottom: 3px; cursor: pointer; }
.traj-item:hover { opacity: .8; }
.traj-item.prev { background: #f1f5f9; border-left: 3px solid #94a3b8; }
.traj-item.curr { background: #fef3c7; border-left: 3px solid #f59e0b; font-weight: 700; cursor: default; }
.traj-item.next { background: #f0fdf4; border-left: 3px solid #22c55e; }
.traj-grade { font-size: 10px; color: #64748b; min-width: 28px; }
.indicator-item { background: #f8fafc; border-radius: 8px; padding: 10px 12px; font-size: 14px; line-height: 1.6; color: #374151; margin-bottom: 6px; }
.concept-card { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 12px 14px; margin-bottom: 8px; }
.concept-name { font-size: 15px; font-weight: 800; color: #1e293b; margin-bottom: 4px; }
.concept-desc { font-size: 14px; color: #374151; line-height: 1.65; }
.source-note { font-size: 12px; color: #94a3b8; line-height: 1.5; margin-top: 6px; }
.relation-list { padding-left: 18px; font-size: 14px; line-height: 1.75; color: #374151; }
.relation-note { color: #64748b; font-size: 13px; }
.objectives-list { padding-left: 18px; font-size: 14px; line-height: 1.8; color: #374151; }
.activity-item { display: flex; align-items: center; gap: 8px; padding: 9px 10px; background: #f8fafc; border-radius: 8px; font-size: 14px; line-height: 1.45; margin-bottom: 5px; }
.activity-num { width: 20px; height: 20px; background: #3b82f6; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; flex-shrink: 0; }
.tool-link { display: inline-block; padding: 6px 12px; background: #eff6ff; color: #1d4ed8; border-radius: 6px; font-size: 14px; text-decoration: none; margin: 2px; }
.tool-link:hover { background: #dbeafe; }
.notes-box { background: #fefce8; border-left: 3px solid #fbbf24; padding: 10px 12px; font-size: 14px; border-radius: 0 8px 8px 0; color: #713f12; line-height: 1.6; }
.empty-hint { color: #94a3b8; font-size: 14px; font-style: italic; }

/* ── 歷年考題 ── */
.exam-section-toggle { cursor: pointer; user-select: none; }
.exam-section-toggle:hover { color: #1d4ed8; }
.exam-section-body { margin-bottom: 8px; }
.exam-q-item { border: 1px solid #e2e8f0; border-radius: 6px; padding: 8px 10px; margin-bottom: 6px; background: #f8fafc; }
.exam-q-label { font-size: 12px; font-weight: 700; color: #64748b; margin-bottom: 4px; }
.exam-q-stem { font-size: 14px; color: #1e293b; line-height: 1.55; }
.exam-q-img { max-width: 100%; border-radius: 4px; margin-top: 6px; cursor: pointer; transition: max-width 0.2s; }
.exam-q-img-full { max-width: 100% !important; }
.exam-q-options { margin-top: 4px; }
.exam-q-option { font-size: 13px; color: #475569; background: #f1f5f9; border-radius: 4px; padding: 3px 6px; margin-bottom: 3px; }
.exam-q-pending { font-size: 11px; color: #94a3b8; font-style: italic; margin-top: 4px; }

/* ── 浮窗卡片 ── */
#float-card {
  display: none; position: fixed; z-index: 20;
  bottom: 20px; right: 20px;
  width: 340px; max-height: 80vh;
  background: white; border: 1px solid #e2e8f0;
  border-radius: 12px; box-shadow: 0 8px 24px rgba(0,0,0,.15);
  overflow: hidden; flex-direction: column;
}
#float-card.visible { display: flex; }
#float-card-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 10px 14px; border-bottom: 1px solid #f1f5f9;
  background: #f8fafc; cursor: grab; user-select: none; flex-shrink: 0;
}
#float-card-header:active { cursor: grabbing; }
#float-card-title { font-size: 12px; font-weight: 700; color: #64748b; }
#float-card-close { background: none; border: none; cursor: pointer; font-size: 16px; color: #94a3b8; padding: 0 4px; line-height: 1; }
#float-card-close:hover { color: #475569; }
#float-card-body { overflow-y: auto; flex: 1; }

/* ── 前置/後續分層列表 ── */
.layer-block { margin-bottom: 8px; }
.layer-header { font-size: 10px; font-weight: 700; color: #94a3b8; letter-spacing: .06em; padding: 4px 0 3px; }
.layer-item { display: flex; align-items: center; gap: 8px; padding: 8px 10px; border-radius: 8px; font-size: 14px; margin-bottom: 5px; cursor: pointer; }
.layer-item:hover { opacity: .8; }
.prereq-item { background: #fff7ed; border-left: 3px solid #f97316; }
.succ-item   { background: #f0fdf4; border-left: 3px solid #22c55e; }
.layer-grade { font-size: 10px; color: #64748b; min-width: 30px; flex-shrink: 0; }
.layer-title { color: #1e293b; }

/* ── 可點擊 indicator chip ── */
.indicator-code { cursor: pointer; transition: background .15s, color .15s; display: inline-block; font-size: 10px; font-weight: 700; color: #6366f1; margin-bottom: 2px; }
.indicator-code:hover { background: #4f46e5; color: white; border-radius: 4px; padding: 1px 4px; }

/* ── 篩選面板 ── */
.filter-header { display: flex; align-items: center; justify-content: space-between; padding: 16px 20px 8px; }
.filter-code-title { font-size: 18px; font-weight: 700; color: #4f46e5; }
.filter-close { background: none; border: none; cursor: pointer; font-size: 18px; color: #94a3b8; padding: 0 4px; line-height: 1; }
.filter-close:hover { color: #475569; }
.filter-desc-text { padding: 0 20px 8px; font-size: 12px; color: #64748b; line-height: 1.5; }
.filter-count { padding: 0 20px 12px; font-size: 11px; font-weight: 700; color: #94a3b8; letter-spacing: .06em; text-transform: uppercase; border-bottom: 1px solid #f1f5f9; }
.filter-unit { border-bottom: 1px solid #f1f5f9; }
.filter-unit-header { display: flex; align-items: center; gap: 8px; padding: 10px 20px; cursor: pointer; user-select: none; flex-wrap: wrap; }
.filter-unit-header:hover { background: #f8fafc; }
.filter-unit-toggle { font-size: 10px; color: #94a3b8; margin-left: auto; transition: transform .15s; }
.filter-unit.collapsed .filter-unit-toggle { transform: rotate(-90deg); }
.filter-unit-body { padding: 0 20px 12px; }
.filter-unit.collapsed .filter-unit-body { display: none; }
.current-grade-badge { font-size: 10px; background: #fef3c7; color: #92400e; border-radius: 10px; padding: 1px 8px; font-weight: 700; }
@keyframes filter-flash { 0%,100% { background: transparent; } 50% { background: #ede9fe; } }
.filter-unit-flash { animation: filter-flash .4s ease; }
</style>
</head>
<body>

<div id="vis-panel">
  <div id="vis-container"></div>
  <div id="toolbar"><!-- rendered by renderToolbar() --></div>
  <div id="strand-legend"></div>
</div>

<div id="card-panel">
  <div class="card-empty">
    <div><div style="font-size:48px;margin-bottom:12px">🗺️</div><div>點選單元<br>查看知識脈絡</div></div>
  </div>
</div>

<div id="float-card">
  <div id="float-card-header">
    <span id="float-card-title">知識脈絡</span>
    <button id="float-card-close">✕</button>
  </div>
  <div id="float-card-body"></div>
</div>

<script src="https://unpkg.com/vis-network/standalone/umd/vis-network.min.js"></script>
<script src="map.js"></script>
</body>
</html>
